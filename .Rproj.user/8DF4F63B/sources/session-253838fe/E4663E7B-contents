## Baby Example: Nonlinear Classification (BART vs GLM)

#To better illustrate the advantage of BART, consider a #simulated dataset with a **nonlinear decision boundary**.

#In this setting:
#- GLM (logistic regression) assumes a linear boundary
#- BART can model complex nonlinear patterns

---





```{r}
library(BART)

set.seed(123)

# Generate data
n <- 200
x1 <- runif(n, -3, 3)
x2 <- runif(n, -3, 3)

# Nonlinear boundary (circle-like pattern)
y <- ifelse(x1^2 + x2^2 < 4, 1, 0)

sim_data <- data.frame(x1 = x1, x2 = x2, y = y)

head(sim_data)
# BART model
x_mat <- as.matrix(sim_data[, c("x1", "x2")])
y_vec <- sim_data$y

set.seed(123)
bart_model <- pbart(x.train = x_mat, y.train = y_vec)
bart_prob <- bart_model$prob.train.mean
bart_pred <- ifelse(bart_prob > 0.5, 1, 0)

# GLM (logistic regression)
glm_model <- glm(y ~ x1 + x2, data = sim_data, family = "binomial")
glm_prob <- predict(glm_model, type = "response")
glm_pred <- ifelse(glm_prob > 0.5, 1, 0)

# Accuracy comparison
bart_acc <- mean(bart_pred == y_vec)
glm_acc <- mean(glm_pred == y_vec)

bart_acc
glm_acc
par(mfrow = c(1,2))

# Plot BART predictions
plot(sim_data$x1, sim_data$x2,
     col = ifelse(bart_pred == 1, "blue", "red"),
     pch = 16,
     main = "BART Classification",
     xlab = "x1", ylab = "x2")

# Plot GLM predictions
plot(sim_data$x1, sim_data$x2,
     col = ifelse(glm_pred == 1, "blue", "red"),
     pch = 16,
     main = "GLM Classification",
     xlab = "x1", ylab = "x2")

par(mfrow = c(1,1))

```


