## Baby Example: BART vs Boosting (mtcars)

We use the `mtcars` dataset to compare:
- **BART**
- **Boosting (GBM)**

We evaluate both models using:
- **Training error**
- **Testing error**

This helps us understand how well each model generalizes.

---

## Step 1: Train-Test Split


```{r}
library(BART)
library(gbm)

set.seed(123)

data(mtcars)

# Create train/test split (70/30)
n <- nrow(mtcars)
train_idx <- sample(1:n, size = floor(0.7 * n))

train <- mtcars[train_idx, ]
test  <- mtcars[-train_idx, ]

# Define predictors and response
x_train <- as.matrix(train[, -1])
y_train <- train$mpg

x_test <- as.matrix(test[, -1])
y_test <- test$mpg

# -----------------------------
# BART MODEL
# -----------------------------
bart_model <- wbart(x.train = x_train, y.train = y_train, x.test = x_test)

bart_train_pred <- bart_model$yhat.train.mean
bart_test_pred  <- bart_model$yhat.test.mean

# -----------------------------
# BOOSTING MODEL
# -----------------------------
boost_model <- gbm(
  mpg ~ .,
  data = train,
  distribution = "gaussian",
  n.trees = 200,
  interaction.depth = 2,
  shrinkage = 0.05,
  bag.fraction = 1.0,      # use all training rows each iteration
  n.minobsinnode = 2,      # smaller minimum node size
  verbose = FALSE
)

boost_train_pred <- predict(boost_model, train, n.trees = 200)
boost_test_pred  <- predict(boost_model, test, n.trees = 200)

# -----------------------------
# COMPARE TRAINING / TEST ERROR
# -----------------------------
bart_train_mse  <- mean((y_train - bart_train_pred)^2)
bart_test_mse   <- mean((y_test - bart_test_pred)^2)

boost_train_mse <- mean((y_train - boost_train_pred)^2)
boost_test_mse  <- mean((y_test - boost_test_pred)^2)

bart_train_mse
bart_test_mse
boost_train_mse
boost_test_mse

# -----------------------------
# TEST SET PLOTS
# -----------------------------
par(mfrow = c(1, 2))

plot(y_test, bart_test_pred,
     col = "blue", pch = 16,
     main = "BART Test Predictions",
     xlab = "Actual MPG",
     ylab = "Predicted MPG")
abline(0, 1, lwd = 2)

plot(y_test, boost_test_pred,
     col = "red", pch = 16,
     main = "Boosting Test Predictions",
     xlab = "Actual MPG",
     ylab = "Predicted MPG")
abline(0, 1, lwd = 2)

par(mfrow = c(1, 1))


```


